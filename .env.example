# Supabase (frontend)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Paystack (frontend — public key only)
VITE_PAYSTACK_PUBLIC_KEY=

# Paystack + app URL — set in Supabase Edge Function secrets for production:
# supabase secrets set PAYSTACK_SECRET_KEY=sk_live_...
# supabase secrets set APP_URL=https://your-production-domain.com
PAYSTACK_SECRET_KEY=
APP_URL=

# SwiftData Ghana — set only in Supabase Edge Function secrets for production:
# supabase secrets set SWIFTDATA_API_KEY=swft_live_...
SWIFTDATA_API_KEY=

# Datamax — set only in Supabase Edge Function secrets for production:
# supabase secrets set DATAMAX_API_KEY=your_key_here
DATAMAX_API_KEY=
